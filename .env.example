# ========================
# OPENROUTER API
# Lấy tại: https://openrouter.ai/keys
# ========================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# (Da go bo Facebook API, bot chi dong vai tro sinh bai)

# ========================
# THÔNG TIN CÔNG TY
# ========================
COMPANY_NAME=Công Ty TNHH Camera An Ninh Việt Nam
COMPANY_ADDRESS=123 Đường ABC, Phường XYZ, Thành phố của bạn
COMPANY_EMAIL=contact@example.com
COMPANY_WEBSITE=https://example.com
COMPANY_HOTLINE=0901 234 567
COMPANY_CITY=Đà Nẵng

# ========================
# CẤU HÌNH BOT
# ========================
# Giờ đăng bài mỗi ngày (định dạng HH:MM)
POST_TIME=06:00
# URL trang san pham (Chon 1 chuyen muc cu the de bot quet hieu qua)
PRODUCTS_URL=https://kabegroup.vn/kabet/product-category/imou/camera-imou/
# Port cho web dashboard
DASHBOARD_PORT=5000
